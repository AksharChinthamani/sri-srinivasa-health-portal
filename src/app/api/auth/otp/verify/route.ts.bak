export const dynamic = 'force-dynamic';

import { NextRequest, NextResponse } from 'next/server';
import { prisma } from '@/lib/db/prisma';
import jwt from 'jsonwebtoken';
import { cookies } from 'next/headers';

const JWT_SECRET = process.env.JWT_SECRET || 'fallback-secret-do-not-use-in-production';

export async function POST(req: NextRequest) {
  try {
    const { action, email, code, name, phone } = await req.json();

    if (!email || !code || !action) {
      return NextResponse.json({ error: 'Email, code, and action are required' }, { status: 400 });
    }

    // 1. Verify OTP
    const otpRecord = await prisma.oTPToken.findFirst({
      where: {
        email,
        code,
        expiresAt: { gt: new Date() },
      },
      orderBy: { createdAt: 'desc' },
    });

    if (!otpRecord) {
      return NextResponse.json({ error: 'Invalid or expired OTP' }, { status: 401 });
    }

    let user;

    // 2. Handle Login Action
    if (action === 'login') {
      user = await prisma.user.findUnique({ where: { email } });
      if (!user) {
        return NextResponse.json({ error: 'User not found. Please register.' }, { status: 404 });
      }
      
      // Enforce that only PATIENTS can login with OTP if that's the requirement.
      // But actually, if they are a patient they shouldn't have passwords anyway.
      // Doctors/Admins can login via the password flow.
    } 
    // 3. Handle Register Action
    else if (action === 'register') {
      const existingUser = await prisma.user.findUnique({ where: { email } });
      if (existingUser) {
        return NextResponse.json({ error: 'Email already registered. Please login.' }, { status: 409 });
      }

      if (!name) {
        return NextResponse.json({ error: 'Name is required for registration' }, { status: 400 });
      }

      user = await prisma.user.create({
        data: {
          name,
          email,
          phone,
          role: 'PATIENT',
          // No password hash required
          patientProfile: {
            create: {}
          }
        },
      });
    } else {
      return NextResponse.json({ error: 'Invalid action' }, { status: 400 });
    }

    // 4. Mark OTP as used by deleting it (or deleting all for this email)
    await prisma.oTPToken.deleteMany({ where: { email } });

    // 5. Generate JWT and Set Cookie
    const token = jwt.sign(
      { id: user.id, email: user.email, role: user.role },
      JWT_SECRET,
      { expiresIn: '7d' }
    );

    cookies().set({
      name: 'token',
      value: token,
      httpOnly: true,
      secure: process.env.NODE_ENV === 'production',
      sameSite: 'lax',
      path: '/',
      maxAge: 60 * 60 * 24 * 7, // 7 days
    });

    return NextResponse.json({
      success: true,
      message: action === 'login' ? 'Logged in successfully' : 'Registered successfully',
      user: { id: user.id, name: user.name, email: user.email, role: user.role },
    });

  } catch (error) {
    console.error('OTP Verify error:', error);
    return NextResponse.json({ error: 'Internal server error' }, { status: 500 });
  }
}
